#!/bin/bash

branch=$1
flag=$2

if [ -z "$branch" ]; then
  echo "Uso: git db <branch> [-f|--force]"
  exit 1
fi

# detectar colaboración por autores
is_collab=false

if [ "$(git shortlog -sne | wc -l)" -gt 1 ]; then
  is_collab=true
fi

if $is_collab; then
  echo "Repo colaborativo detectado (múltiples autores)"
  read -p "Esto puede afectar a otros. Continuar? (y/N): " confirm
  if [ "$confirm" != "y" ]; then
    echo "Cancelado."
    exit 1
  fi
fi

# evitar borrar la rama actual
current=$(git branch --show-current)

if [ "$current" = "$branch" ]; then
  echo "No puedes borrar la rama en la que estás parado"
  exit 1
fi

# borrar remoto si existe
if git remote | grep -q origin; then
  git push origin --delete "$branch"
fi

# borrar local
if [ "$flag" = "-f" ] || [ "$flag" = "--force" ]; then
  git branch -D "$branch"
else
  git branch -d "$branch"
fi
